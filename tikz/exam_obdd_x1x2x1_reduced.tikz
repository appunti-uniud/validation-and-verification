\begin{tikzpicture}[baseline=(x1.base)]
  \node[bvar]  (x1) at (0,2.6)  {$x_1$};
  \node[bvar]  (x2) at (1.3,1.3){$x_2$};
  \node[bleaf] (l0) at (0,0)    {$0$};
  \node[bleaf] (l1) at (2.6,0)  {$1$};
  \draw[blow]  (x1) -- (l0);  \draw[bhigh] (x1) -- (x2);
  \draw[blow]  (x2) -- (l0);  \draw[bhigh] (x2) -- (l1);
\end{tikzpicture}
